generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum GameStatus {
  SCHEDULED
  IN_PROGRESS
  FINAL
}

// ─── NextAuth Required Models ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ───────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  isPaid        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  picks    Pick[]
}

model Team {
  id         String  @id @default(cuid())
  espnId     String  @unique
  name       String
  shortName  String
  seed       Int
  region     String
  isPlayIn   Boolean @default(false)
  eliminated Boolean @default(false)
  wins       Int     @default(0)
  logoUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  picks        Pick[]
  playInSlot1  PlayInSlot[]     @relation("PlayInTeam1")
  playInSlot2  PlayInSlot[]     @relation("PlayInTeam2")
  playInWinner PlayInSlot[]     @relation("PlayInWinner")
  team1Games   TournamentGame[] @relation("GameTeam1")
  team2Games   TournamentGame[] @relation("GameTeam2")
  wonGames     TournamentGame[] @relation("GameWinner")
}

model PlayInSlot {
  id       String  @id @default(cuid())
  seed     Int
  region   String
  team1Id  String
  team2Id  String
  winnerId String?

  team1  Team  @relation("PlayInTeam1", fields: [team1Id], references: [id])
  team2  Team  @relation("PlayInTeam2", fields: [team2Id], references: [id])
  winner Team? @relation("PlayInWinner", fields: [winnerId], references: [id])
  picks  Pick[]

  @@unique([seed, region])
}

model Pick {
  id                String   @id @default(cuid())
  userId            String
  teamId            String?
  playInSlotId      String?
  charityPreference String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  team       Team?       @relation(fields: [teamId], references: [id])
  playInSlot PlayInSlot? @relation(fields: [playInSlotId], references: [id])

  @@unique([userId, teamId])
  @@unique([userId, playInSlotId])
}

model TournamentGame {
  id         String     @id @default(cuid())
  espnGameId String     @unique
  round      Int
  team1Id    String?
  team2Id    String?
  winnerId   String?
  team1Score Int?
  team2Score Int?
  status     GameStatus @default(SCHEDULED)
  startTime  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  team1  Team? @relation("GameTeam1", fields: [team1Id], references: [id])
  team2  Team? @relation("GameTeam2", fields: [team2Id], references: [id])
  winner Team? @relation("GameWinner", fields: [winnerId], references: [id])
}

model AppSettings {
  id               String    @id @default("main")
  picksDeadline    DateTime?
  payoutStructure  Json      @default("[]")
  defaultCharities Json      @default("[]")
  updatedAt        DateTime  @updatedAt
}

model ContentPage {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  content     String   @db.Text
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
